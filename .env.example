# LLM provider.
# Default: OpenRouter primary. To switch to Groq, set LLM_PROVIDER=groq.
LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_EXTRACTION_MODEL=qwen/qwen3-next-80b-a3b-instruct
OPENROUTER_SYNTHESIS_MODEL=qwen/qwen3-next-80b-a3b-instruct
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Blostem Battlecard Studio

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
# Optional Groq-specific overrides if you want different models per step.
GROQ_EXTRACTION_MODEL=openai/gpt-oss-120b
GROQ_SYNTHESIS_MODEL=openai/gpt-oss-120b

# Live retrieval providers. Use Tavily or Serper for demo-day freshness.
TAVILY_API_KEY=tvly_your_tavily_key_here
SERPER_API_KEY=your_serper_key_here
RETRIEVAL_PROVIDER=auto

# Optional scraper provider.
FIRECRAWL_API_KEY=fc_your_firecrawl_key_here

# Default should stay live for judging. Use demo only for deterministic rehearsals.
DEFAULT_RETRIEVAL_MODE=live
